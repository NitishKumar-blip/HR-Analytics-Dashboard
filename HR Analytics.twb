          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Palo Alto Networks' name='federated.09k6c6g13nnmzp1ejvh9a1otij7w' />
          </datasources>
          <datasource-dependencies datasource='federated.09k6c6g13nnmzp1ejvh9a1otij7w'>
