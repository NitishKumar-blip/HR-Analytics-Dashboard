      <aliases enabled='yes' />
      <column datatype='integer' name='[Attrition]' role='measure' type='quantitative' />
      <column caption='Business Travel' datatype='string' name='[BusinessTravel]' role='dimension' type='nominal' />
      <column caption='rate by distance' datatype='real' name='[Calculation_1454934480699392]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Attrition])/([Calculation_1689955022716935])' />
      </column>
      <column caption='Engagement Index' datatype='real' datatype-customized='true' name='[Calculation_1689954836242432]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([JobInvolvement])+AVG([JobSatisfaction])+AVG([RelationshipSatisfaction])+AVG([EnvironmentSatisfaction]))/4' />
      </column>
      <column caption='Burnout Risk Sscore' datatype='integer' name='[Calculation_1689954841010177]' role='measure' type='quantitative'>
